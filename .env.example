# MCP Server Secret Token
# Used for token-based authentication on all requests
MCP_SECRET=changeme

# Proxy Allowed Domains
# Comma-separated list of domains that can be fetched via fetch_external tool
PROXY_ALLOWED_DOMAINS=api.github.com

# GitHub Token
# Used for automatic authentication to api.github.com via fetch_external tool
GITHUB_TOKEN=your_github_token_here

# Tailscale API Key
# Get from: https://login.tailscale.com/admin/settings/keys
TAILSCALE_API_KEY=your_tailscale_api_key_here

# Telegram Bot Token
# Create a bot with @BotFather on Telegram, then copy the token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Default Chat ID
# Send a message to your bot and check the chat ID
# Or use @userinfobot to get your user ID
DEFAULT_CHAT_ID=your_chat_id_here

# Server port (optional, defaults to 3000)
PORT=3000
