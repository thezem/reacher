# Secret token for authenticating requests to this MCP server
# Claude.ai will send this with every request - set it to something random and long
# Generate with: openssl rand -hex 32
MCP_SECRET=changeme

# Tailscale API key for querying your device network
# Create one at: https://login.tailscale.com/admin/settings/keys
# Needs "Devices (read)" scope
TAILSCALE_API_KEY=your_tailscale_api_key_here

# GitHub personal access token
# Used for fetch_external auth injection to api.github.com and for gist_kb read/write
# Create at: https://github.com/settings/tokens
# Needs: gist (read+write), and any other scopes for APIs you want to proxy
GITHUB_TOKEN=your_github_token_here

# Comma-separated list of domains that fetch_external is allowed to call
# Auth tokens are injected automatically based on the domain (e.g. GITHUB_TOKEN for api.github.com)
# Example: api.github.com,api.linear.app,api.notion.com
PROXY_ALLOWED_DOMAINS=api.github.com

# HTTP port for the server (optional, defaults to 3000)
PORT=3000

# Dry-run mode - when true, ssh_exec will not actually execute commands
# Useful for testing and validation without side effects
# Can also be set in reacher.config.yaml
DRY_RUN=false

# Enable or disable audit logging
# When enabled, all tool calls are logged to AUDIT_LOG_PATH
# Can also be set in reacher.config.yaml
AUDIT_ENABLED=true

# Path to audit log file
# Supports relative and absolute paths
# Can also be set in reacher.config.yaml
AUDIT_LOG_PATH=./reacher-audit.log

# SSH blocked commands - comma-separated list of commands to block
# Supports substring matching (case-insensitive)
# Example: rm -rf /,shutdown,reboot,mkfs,dd,format
# Can also be set in reacher.config.yaml as ssh.blocked_commands
SSH_BLOCKED_COMMANDS=rm -rf /,shutdown,reboot,mkfs,dd,format

# SSH allowed directories - comma-separated list of directories where SSH commands are allowed
# If empty, all directories are allowed (no restriction)
# Uses prefix matching - a path is allowed if it starts with one of these directories
# Example: /home/user,/tmp,/var/log
# Can also be set in reacher.config.yaml as ssh.allowed_dirs
SSH_ALLOWED_DIRS=

# Token injection mapping (optional, for advanced use)
# Maps domains to environment variable names for automatic header injection
# Format: {"domain.com":"ENV_VAR_NAME"}
# Example: {"api.github.com":"GITHUB_TOKEN","api.linear.app":"LINEAR_API_TOKEN"}
FETCH_EXTERNAL_TOKEN_MAP={"api.github.com":"GITHUB_TOKEN"}

# Browser configuration (optional, for headless browser tool)
# Host of the CDP-compatible browser (defaults to 127.0.0.1)
# BROWSER_CDP_HOST=127.0.0.1

# Port of the CDP-compatible browser (defaults to 9222)
# BROWSER_CDP_PORT=9222
