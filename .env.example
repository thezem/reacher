# Secret token for authenticating requests to this MCP server
# Claude.ai will send this with every request - set it to something random and long
MCP_SECRET=changeme

# Tailscale API key for querying your device network
# Create one at: https://login.tailscale.com/admin/settings/keys
# Needs "Devices (read-only)" scope at minimum
TAILSCALE_API_KEY=your_tailscale_api_key_here

# GitHub personal access token
# Used for fetch_external auth injection to api.github.com and for gist_kb read/write
# Needs: gist (read+write), and any other scopes for APIs you want to proxy
GITHUB_TOKEN=your_github_token_here

# Comma-separated list of domains that fetch_external is allowed to call
# Auth tokens are injected automatically based on the domain (e.g. GITHUB_TOKEN for api.github.com)
PROXY_ALLOWED_DOMAINS=api.github.com

# HTTP port for the server (optional, defaults to 3000)
PORT=3000

CLAUDE_JOBS_DIR=./claude_jobs
FETCH_EXTERNAL_TOKEN_MAP={"api.github.com":"GITHUB_TOKEN"}