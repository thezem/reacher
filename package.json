{
  "name": "personal-mcp-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Modular MCP server for personal tools - SSH, Tailscale, file upload, Telegram",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "docker:build": "docker build -t mcp-server .",
    "docker:run": "docker run -p 3000:3000 --env-file .env mcp-server",
    "docker:run:prod": "docker run -d -p 3000:3000 --env-file .env --restart unless-stopped mcp-server"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ssh",
    "tailscale",
    "telegram"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "dotenv": "16.6.1",
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
