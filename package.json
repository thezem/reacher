{
  "name": "reacher",
  "version": "0.1.0",
  "type": "module",
  "description": "Self-hosted MCP server for SSH, API proxying, browser automation, and persistent AI memory",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/thezem/reacher"
  },
  "homepage": "https://github.com/thezem/reacher#readme",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "node --test tests/*.test.js",
    "docker:build": "docker build -t mcp-server .",
    "docker:run": "docker run -p 3000:3000 --env-file .env mcp-server",
    "docker:run:prod": "docker run -d -p 3000:3000 --env-file .env --restart unless-stopped mcp-server"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ssh",
    "tailscale",
    "telegram"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "agent-browser": "latest",
    "dotenv": "16.6.1",
    "express": "^4.19.2",
    "js-yaml": "4.1.1",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
